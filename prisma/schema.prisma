generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin") // "super_admin" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageSection {
  id         String   @id @default(cuid())
  page       String
  sectionKey String
  title      String?
  subtitle   String?
  content    Json?
  imageUrl   String?
  order      Int      @default(0)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([page, sectionKey])
  @@index([page])
}

model Service {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  icon         String?
  imageUrl     String?
  price          String?
  originalPrice  String?
  sampleImageUrl String?
  inclusions   Json?
  processSteps Json?
  deliverables Json?
  order        Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  price        String
  features     Json
  timeline     String?
  samplePdfUrl String?
  isFeatured   Boolean  @default(false)
  order        Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       String?
  originalPrice String?
  imageUrl    String?
  category    String?
  area        String?
  budget      String?
  floors      Int?
  direction   String?
  width       Float?
  depth       Float?
  bhk         String?
  vastu       String?    @default("Doesn't Matter")
  code        String?    @unique
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryCategory {
  id    String        @id @default(cuid())
  name  String        @unique
  order Int           @default(0)
  items GalleryItem[]
}

model GalleryItem {
  id          String          @id @default(cuid())
  title       String?
  description String?
  imageUrl    String
  categoryId  String
  category    GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order       Int             @default(0)
  isVisible   Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  content   String
  rating    Int      @default(5)
  imageUrl  String?
  isVisible Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model LegalPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

model GlobalSettings {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

// ─── Calculators ───────────────────────────────────────
model Calculator {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  fields      Json     // Array of {name, label, type, min, max, defaultValue, unit, options}
  formula     String   // JS expression e.g. "area * rate * floors"
  resultLabel String   @default("Estimated Result")
  resultUnit  String   @default("₹")
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CTA Section ───────────────────────────────────────
model CtaSection {
  id         String  @id @default(cuid())
  headline   String
  subtext    String?
  buttonText String  @default("Get Started")
  buttonUrl  String  @default("/contact")
  isVisible  Boolean @default(true)
  order      Int     @default(0)
}

// ─── Chat Sessions & Messages ──────────────────────────
model ChatSession {
  id        String        @id @default(cuid())
  guestName String?
  email     String?
  phone     String?
  ipAddress String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([createdAt])
  @@index([email])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" or "bot"
  content   String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

// ─── Home Page Content ──────────────────────────────────
model HomePage {
  id              String   @id @default("singleton")
  headerTitle     String?
  headerSubtitle  String?
  heroTitle       String?
  heroDescription String?
  heroButtonText  String?  @default("Explore Services")
  heroButtonLink  String?  @default("/services")
  
  // New Fields for Header/Footer/Contact
  contactEmail    String?
  contactPhone    String?
  whatsappNumber  String?
  address         String?
  socialLinks     Json?    // Array of { platform, url }
  quickLinks      Json?    // Array of { label, href }
  legalLinks      Json?    // Array of { label, href }
  footerContent   String?

  sections        Json?    // For flexible sections if needed
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  ogImage         String?
  updatedAt       DateTime @updatedAt
}

// ─── Payments & Transactions ──────────────────────────────
model Payment {
  id                String   @id @default(cuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  amount            Float
  currency          String   @default("INR")
  status            String   @default("PENDING") // PENDING, PAID, FAILED, CANCELLED
  userEmail         String?
  userName          String?
  userPhone         String?
  planId            String?
  productId         String?
  metadata          Json?    // For any additional info
  referrerId        String?
  referrer          Referrer? @relation(fields: [referrerId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([razorpayOrderId])
  @@index([userEmail])
  @@index([referrerId])
}

// ─── Referral System ──────────────────────────────────
model Referrer {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  referralCode String    @unique
  payments     Payment[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([referralCode])
}
